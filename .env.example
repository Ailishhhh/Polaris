# Ascend mobile app — public runtime config (Expo inlines EXPO_PUBLIC_* at build time)
# Copy to .env and fill in. Never commit your real .env.

# Supabase (Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mentor backend (deployed on Render). For local backend dev, use your LAN IP instead.
EXPO_PUBLIC_API_URL=https://polaris-mentor-api.onrender.com
