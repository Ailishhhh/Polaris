# Ascend mobile app — public runtime config (Expo inlines EXPO_PUBLIC_* at build time)
# Copy to .env and fill in. Never commit your real .env.

# Supabase (Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mentor backend (the server/ in this repo, e.g. your Render URL)
# For local dev with Expo Go on a physical device, use your machine's LAN IP,
# not localhost (the phone can't reach your laptop's localhost).
EXPO_PUBLIC_API_URL=http://localhost:8787
