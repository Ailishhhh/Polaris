# Ascend mentor backend
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=8787
NODE_ENV=development

# Comma-separated allowed origins, or * for all (fine for a public app API)
CORS_ORIGINS=*


# OPTIONAL free fallback LLM (OpenAI-compatible). Leave blank to run Gemini-only.
# IMPORTANT: Gemini's free tier is only ~20 requests/day. For a real free
# deployment, get a free Groq key (no credit card) and make it PRIMARY:
#   https://console.groq.com/keys
# FALLBACK_BASE_URL=https://api.groq.com/openai/v1
# FALLBACK_API_KEY=gsk_your_free_groq_key
# FALLBACK_MODEL=llama-3.3-70b-versatile
# LLM_PRIMARY=fallback     # use Groq first (~14,400/day), Gemini as backup
